    "format": "prettier --write *.js test/*.js README.md",
    "check-format": "prettier --check *.js test/*.js README.md"
  },
  "dependencies": {
    "@waysidemapping/pinhead": "^14.0.0",
    "tinycolor2": "^1.6.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1"
  }
}
