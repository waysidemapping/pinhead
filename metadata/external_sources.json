[
  {
    "id": "americana",
    "name": "OSM Americana",
    "repo": "https://github.com/osm-americana/openstreetmap-americana.git",
    "iconDir": "icons",
    "ignoreFiles": "^(shield)|(oneway)"
  },
  {
    "id": "healthicons",
    "name": "Health Icons",
    "repo": "https://github.com/resolvetosavelives/healthicons.git",
    "iconDir": "public/icons/svg/filled-24px"
  },
  {
    "id": "maki",
    "name": "Maki",
    "repo": "https://github.com/mapbox/maki.git",
    "iconDir": "icons"
  },
  {
    "id": "nps",
    "name": "NPS",
    "repo": "https://github.com/nationalparkservice/symbol-library.git",
    "iconDir": "src/standalone",
    "filenameSuffix": "-black-22",
    "ignoreFiles": "^transparent"
  },
  {
    "id": "opengemeenten",
    "name": "OpenGemeenten",
    "repo": "https://github.com/OpenGemeenten/Iconenset.git",
    "iconDir": "Svg/Regular diapositive"
  },
  {
    "id": "opentrailmap",
    "name": "OpenTrailMap",
    "repo": "https://github.com/osmus/opentrailmap.git",
    "iconDir": "style/sprites/svg",
    "ignoreFiles": "^(oneway-)|(fill-)|(stroke-)"
  },
  {
    "id": "osmcarto",
    "name": "OSM Carto",
    "repo": "https://github.com/openstreetmap-carto/openstreetmap-carto.git",
    "iconDir": "symbols",
    "ignoreFiles": "(^generating_patterns\\/)|(^shields\\/)|(^unpaved\\/)|(^[^/]+$)"
  },
  {
    "id": "temaki",
    "name": "Temaki",
    "repo": "https://github.com/rapideditor/temaki.git",
    "iconDir": "icons"
  },
  {
    "id": "viglino",
    "name": "Viglino",
    "repo": "https://github.com/Viglino/map-font-symbols.git",
    "ignoreFiles": "^(?!.*(princesse\/svg\/|pirate\/svg\/)).*|.*\/old\/.*$"
  }
]